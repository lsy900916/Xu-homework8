# ==================== Database ====================
# SQLite databases
*.db
*.sqlite
*.sqlite3

# Database data directories
backend/data/*.db
backend/data/*.sqlite

# Keep directory structure
!backend/data/.gitkeep

# ==================== FAISS ====================
# FAISS index files
backend/data/faiss_indexes/*.index
backend/data/faiss_indexes/backup/*.index

# Keep directory structure
!backend/data/faiss_indexes/.gitkeep
!backend/data/faiss_indexes/backup/.gitkeep

# ==================== Logs ====================
# Log files
*.log
logs/
*.log.*

# Keep log directories
!logs/.gitkeep

